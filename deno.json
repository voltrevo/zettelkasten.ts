{
  "name": "zettelkasten",
  "version": "0.1.0",
  "exports": "./main.ts",
  "imports": {
    "@noble/hashes/sha3": "npm:@noble/hashes@^1.6.0/sha3",
    "@std/cli/parse-args": "jsr:@std/cli@^1.0.28/parse-args",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "typescript": "npm:typescript@^5.8.2"
  },
  "fmt": {
    "exclude": ["samples/"]
  },
  "lock": {
    "frozen": false,
    "exclude": ["http://localhost:8000"]
  },
  "tasks": {
    "zts": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run --allow-import main.ts",
    "test": "deno test --allow-env src/",
    "precommit": "deno fmt && deno check main.ts && deno test --allow-env src/ && deno lint"
  }
}
